{
  "WebApi": {
    "ApplicationSettings": {
      "Name": "[DEV] Dilcore Platform API"
    },
    "MongoDbSettings": {
      "ConnectionString": "$(MONGODB_MONGODB_CONNECTION_STRING)"
    },
    "GrainsSettings": {
      "StorageAccountName": "$(PLATFORM_GRAIN_STORAGE_ACCOUNT_NAME)"
    },
    "AuthenticationSettings": {
      "Auth0": {
        "Domain": "$(AUTH0_DOMAIN)",
        "ClientId": "$(AUTH0_API_DOC_CLIENT_ID)",
        "ClientSecret": "$(AUTH0_API_DOC_CLIENT_SECRET)",
        "Audience": "$(AUTH0_API_AUDIENCE)"
      }
    },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning"
      }
    }
  },
  "WebApp": {
    "ApplicationSettings": {
      "Name": "[DEV] Dilcore Platform"
    },
    "AuthenticationSettings": {
      "Auth0": {
        "Domain": "$(AUTH0_DOMAIN)",
        "ClientId": "$(AUTH0_WEB_APP_CLIENT_ID)",
        "ClientSecret": "$(AUTH0_WEB_APP_CLIENT_SECRET)",
        "Audience": "$(AUTH0_API_AUDIENCE)",
        "Scope": "openid profile email offline_access"
      }
    },
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning"
      }
    },
    "ApiSettings": {
      "BaseUrl": "$(PLATFORM_API_BASE_URL)"
    }
  },
  "AIAgent": {
        "ApplicationSettings": {
            "Name": "[DEV] Dilcore AI Agent",
            "Debug": false,
            "LogLevel": "INFO",
            "CorsOrigins": [
                "*"
            ]
        },
        "OpenRouterSettings": {
            "ApiKey": "$(OPEN_ROUTER_MODELS_AI_CORE_API_KEY)",
            "BaseUrl": "https://openrouter.ai/api/v1",
            "Model": "ogoogle/gemini-2.5-flash-lite"
        },
        "AuthenticationSettings": {
            "Auth0": {
                "Domain": "$(AUTH0_DOMAIN)",
                "ClientId": "$(AUTH0_API_DOC_CLIENT_ID)",
                "ClientSecret": "$(AUTH0_API_DOC_CLIENT_SECRET)",
                "Audience": "$(AUTH0_API_AUDIENCE)"
            }
        },
        "MongoDbSettings": {
            "ConnectionString": "$(MONGODB_MONGODB_CONNECTION_STRING)",
            "DbName": "langgraph_checkpoints"
        },
        "VectorStoreSettings": {
            "Provider": "faiss",
            "BasePath": "./data/vector_store",
            "MetadataIndexName": "metadata_index",
            "DataIndexName": "data_index",
            "EmbeddingModel": "openai/text-embedding-3-small"
        },
        "AzureTelemetry": {
            "ApplicationInsightsConnectionString": "$(AI_AGENT_APPLICATION_INSIGHTS_CONNECTION_STRING)"
        },
        "LangSmithSettings": {
            "TracingEnabled": true,
            "Endpoint": "https://eu.api.smith.langchain.com",
            "ApiKey": "$(AI_AGENT_LANGSMITH_API_KEY)",
            "Project": "Dilcore AI Agent"
        },
        "Logging": {
            "LogLevel": {
                "Default": "INFO"
            }
        },
        "ApiSettings": {
            "BaseUrl": "$(PLATFORM_API_BASE_URL)"
        }
    }
  }